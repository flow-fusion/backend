# =============================================================================
# FlowFusion Production Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=change_this_secure_password_in_production
DB_NAME=flowfusion

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_this_secure_password_in_production

# -----------------------------------------------------------------------------
# GitLab Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Secret token for webhook validation - generate a random string
GITLAB_WEBHOOK_SECRET=generate_random_secret_min_32_chars

# GitLab API token for reading commit diffs and MR info
# Create at: https://gitlab.com/-/profile/personal_access_tokens
# Scopes: read_api, read_repository
GITLAB_API_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab instance URL (use your self-hosted URL if applicable)
GITLAB_BASE_URL=https://gitlab.com

# -----------------------------------------------------------------------------
# Jira Configuration (REQUIRED for Jira integration)
# -----------------------------------------------------------------------------
# Your Jira instance URL
JIRA_URL=https://your-company.atlassian.net

# Jira user email (must have API token)
JIRA_EMAIL=your-email@company.com

# Jira API token
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your_jira_api_token_here

# Auto-post AI summaries to Jira issues (true/false)
JIRA_AUTO_POST=true

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Debug mode (false for production!)
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log format (json or text)
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Processing Configuration
# -----------------------------------------------------------------------------
# Time window for batching commits (minutes)
COMMIT_BATCH_WINDOW_MINUTES=30

# Maximum retry attempts for failed events
MAX_RETRIES=3

# Delay between retries (seconds)
RETRY_DELAY_SECONDS=60
