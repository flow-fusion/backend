# =============================================================================
# FlowFusion Production Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (REQUIRED)
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
DB_NAME=flowfusion

# -----------------------------------------------------------------------------
# Redis Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# -----------------------------------------------------------------------------
# GitLab Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Secret token for webhook validation - generate a random string (32+ chars)
GITLAB_WEBHOOK_SECRET=generate_random_secret_min_32_chars_here

# GitLab API token for reading commit diffs and MR info (OPTIONAL but recommended)
# Create at: https://gitlab.com/-/profile/personal_access_tokens
# Scopes: read_api, read_repository
GITLAB_API_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab instance URL (use your self-hosted URL if applicable)
GITLAB_BASE_URL=https://gitlab.com

# -----------------------------------------------------------------------------
# Jira Integration (OPTIONAL)
# -----------------------------------------------------------------------------
# Your Jira instance URL
JIRA_URL=https://your-company.atlassian.net

# Jira user email (must have API token)
JIRA_EMAIL=your-email@company.com

# Jira API token
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your_jira_api_token_here

# Auto-post AI summaries to Jira issues (true/false)
JIRA_AUTO_POST=false

# -----------------------------------------------------------------------------
# AI Configuration (OPTIONAL - for AI-generated summaries)
# -----------------------------------------------------------------------------
# Provider options: ollama (local), openai, openrouter, anthropic, google

# For Ollama:
AI_PROVIDER=ollama
AI_MODEL=llama3.2
AI_AUTO_GENERATE=true

# For OpenAI:
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AI_MODEL=gpt-4o-mini
# AI_AUTO_GENERATE=true

# For OpenRouter:
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
# AI_MODEL=openai/gpt-4o-mini
# AI_AUTO_GENERATE=true

# For Anthropic Claude:
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# AI_MODEL=claude-3-haiku-20240307
# AI_AUTO_GENERATE=true

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Processing Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
COMMIT_BATCH_WINDOW_MINUTES=30
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60
