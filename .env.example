# Application Configuration
APP_NAME=FLOWFUSION
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flowfusion
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Event Queue
EVENT_QUEUE_NAME=event_queue
EVENT_RETRY_QUEUE_NAME=event_retry_queue
EVENT_DEAD_LETTER_QUEUE_NAME=event_dead_letter_queue

# Processing
COMMIT_BATCH_WINDOW_MINUTES=30
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60

# GitLab API (for context enrichment)
GITLAB_BASE_URL=https://gitlab.com
GITLAB_API_TOKEN=your_gitlab_api_token_here
GITLAB_API_TIMEOUT=30
GITLAB_API_RETRY_COUNT=3

# GitLab Webhook (REQUIRED)
GITLAB_WEBHOOK_SECRET=your_webhook_secret_here

# Jira Integration (OPTIONAL - for auto-posting to Jira)
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your_jira_api_token
JIRA_AUTO_POST=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
