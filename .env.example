# Application Configuration
APP_NAME=AI Concurs Backend
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_concurs
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Event Queue
EVENT_QUEUE_NAME=event_queue
EVENT_RETRY_QUEUE_NAME=event_retry_queue
EVENT_DEAD_LETTER_QUEUE_NAME=event_dead_letter_queue

# Processing
COMMIT_BATCH_WINDOW_MINUTES=30
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
